{
  "name": "Python 3.12",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "charliermarsh.ruff",
        "ms-python.black-formatter",
        "ms-python.isort",
        "eamodio.gitlens",
        "github.copilot"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        },
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },

  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": { "label": "FastAPI / Dev Server" }
  },

  "postCreateCommand": "pip install -r requirements.txt 2>/dev/null || pip install -r requirements-dev.txt 2>/dev/null || true",
  "remoteUser": "vscode"
}
